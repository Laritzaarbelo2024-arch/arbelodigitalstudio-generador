<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Arbelo Digital | Generador Aesthetic</title>
    <style>
        :root {
            --green-dark: #1b5e20;
            --green-main: #2e7d32;
            --green-bright: #4caf50;
            --bg-light: #f1f8e9;
        }
        body { font-family: 'Helvetica Neue', Arial, sans-serif; background-color: var(--bg-light); display: flex; justify-content: center; align-items: center; min-height: 100vh; margin: 0; padding: 20px; }
        .container { background: white; padding: 40px; border-radius: 25px; box-shadow: 0 15px 35px rgba(46, 125, 50, 0.1); max-width: 500px; width: 100%; text-align: center; border-top: 8px solid var(--green-main); }
        
        h1 { color: var(--green-dark); margin-bottom: 5px; font-size: 26px; font-weight: 800; }
        .subtitle { color: var(--green-bright); margin-bottom: 30px; font-size: 12px; text-transform: uppercase; letter-spacing: 2px; font-weight: bold; }
        
        label { display: block; text-align: left; font-weight: 600; margin-bottom: 10px; color: #333; font-size: 14px; }
        select { width: 100%; padding: 14px; margin-bottom: 25px; border: 2px solid #e8f5e9; border-radius: 12px; font-size: 16px; background-color: #f9fff9; color: #333; outline: none; }
        select:focus { border-color: var(--green-bright); }
        
        button { background: var(--green-main); color: white; border: none; padding: 18px; border-radius: 12px; font-size: 16px; font-weight: bold; cursor: pointer; width: 100%; transition: all 0.3s; box-shadow: 0 4px 15px rgba(46, 125, 50, 0.2); }
        button:hover { background: var(--green-dark); transform: translateY(-2px); }
        
        #result-container { margin-top: 30px; display: none; text-align: left; animation: fadeIn 0.5s; }
        #result-text { padding: 20px; background-color: #f9fff9; border-radius: 12px; border: 1px dashed var(--green-bright); border-left: 5px solid var(--green-main); font-size: 14px; color: #333; line-height: 1.6; }
        
        .back-btn { margin-top: 25px; display: inline-block; color: var(--green-main); text-decoration: none; font-size: 14px; font-weight: bold; transition: color 0.3s; }
        .back-btn:hover { color: var(--green-dark); text-decoration: underline; }

        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
    </style>
</head>
<body>

<div class="container">
    <h1>Arbelo Digital Studio</h1>
    <div class="subtitle">Generador de Imágenes IA</div>
    
    <label>🎨 ¿Qué vas a crear hoy?</label>
    <select id="tipo">
        <option value="un mockup de producto premium (como un sérum de lujo)">Mockup de Producto Elite</option>
        <option value="un fondo para historias de Instagram aesthetic">Fondo para Stories</option>
        <option value="una portada de Ebook profesional y minimalista">Portada de Ebook</option>
        <option value="una escena de escritorio con laptop y café">Escena de Trabajo (Desk Setup)</option>
    </select>

    <label>✨ Selecciona el Estilo Visual</label>
    <select id="estilo">
        <option value="estilo editorial de revista de lujo, alta costura, iluminación cinematográfica, sombras suaves">Luxury Editorial (Premium)</option>
        <option value="estilo 'Clean Girl aesthetic', tonos beige y blanco, luz natural orgánica, minimalista">Clean Girl (Beige/Blanco)</option>
        <option value="estilo moderno con colores pastel, mucha luz y texturas suaves">Minimalista Pastel</option>
    </select>

    <button onclick="generar()">GENERAR PROMPT PARA IA</button>

    <div id="result-container">
        <label>Copia este prompt para Midjourney o DALL-E:</label>
        <div id="result-text"></div>
    </div>

    <a href="index.html" class="back-btn">← Volver al Menú Principal</a>
</div>

<script>
    function generar() {
        const tipo = document.getElementById('tipo').value;
        const estilo = document.getElementById('estilo').value;
        const prompt = `Crea ${tipo}, ${estilo}. Calidad 8k, ultra detallado, fotografía profesional de producto, listo para marketing de alto nivel.`;
        document.getElementById('result-text').innerText = prompt;
        document.getElementById('result-container').style.display = 'block';
    }
</script>

</body>
</html>
